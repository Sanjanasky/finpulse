# FinPulse RAG — Environment Variables
# Copy this file to .env and fill in values if needed.
# For local-only mode (Ollama), none of these are required.

# ── Optional: Cloud LLM fallbacks ──────────────────────────────
# Only needed if you want to use cloud APIs instead of Ollama.
# Leave blank for fully local mode.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Ollama settings (defaults work for most setups) ────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Embedding model ────────────────────────────────────────────
# Change to a larger model for better retrieval quality.
# Options: all-MiniLM-L6-v2 | BAAI/bge-small-en-v1.5 | BAAI/bge-base-en-v1.5
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Chunking ───────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
